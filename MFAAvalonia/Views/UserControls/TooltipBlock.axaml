<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:MFAAvalonia.Views.UserControls"
                    xmlns:full="https://github.com/whistyun/Markdown.Avalonia"
                    xmlns:extensions="clr-namespace:MFAAvalonia.Extensions">
    <ControlTheme x:Key="{x:Type controls:TooltipBlock}" TargetType="controls:TooltipBlock">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Name="PART_Border"
                        Width="15"
                        Height="15" CornerRadius="8"
                        Margin="2,0,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource MouseOverRegionBrush}">

                    <FlyoutBase.AttachedFlyout>
                        <Flyout Placement="Bottom" ShowMode="Standard" VerticalOffset="6">
                            <Flyout.FlyoutPresenterTheme>
                                <ControlTheme TargetType="FlyoutPresenter">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="CornerRadius" Value="0" />
                                    <Setter Property="Template">
                                        <ControlTemplate>
                                            <ContentPresenter Content="{TemplateBinding Content}"
                                                              Margin="8" />
                                        </ControlTemplate>
                                    </Setter>
                                </ControlTheme>
                            </Flyout.FlyoutPresenterTheme>
                            <Border MaxWidth="{Binding TooltipMaxWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="400"
                                    Padding="8,3,8,8"
                                    CornerRadius="8"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource SukiControlBorderBrush}"
                                    BoxShadow="0 4 12 0 #40000000"
                                    Background="{DynamicResource SukiCardBackground}">
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <full:MarkdownScrollViewer
                                        Markdown="{Binding TooltipText, RelativeSource={RelativeSource TemplatedParent}}"
                                        VerticalAlignment="Top">
                                        <full:MarkdownScrollViewer.Engine>
                                            <extensions:MarkdownExtension />
                                        </full:MarkdownScrollViewer.Engine>
                                        <full:MarkdownScrollViewer.Plugins>
                                            <StaticResource ResourceKey="MdXamlPlugin" />
                                        </full:MarkdownScrollViewer.Plugins>
                                        <full:MarkdownScrollViewer.Styles>
                                            <StyleInclude Source="avares://MFAAvalonia.Core/Assets/Style/MdXamlStyles.axaml" />
                                        </full:MarkdownScrollViewer.Styles>
                                    </full:MarkdownScrollViewer>
                                </ScrollViewer>
                            </Border>
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>

                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center" TextAlignment="Center"
                               FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource SukiPrimaryColor}"
                               Text="?" />
                </Border>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
